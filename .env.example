# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bolster:password@localhost:5432/bolster_dev
DATABASE_URL_TEST=postgresql://bolster:password@localhost:5432/bolster_test

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-min-32-chars-access-secret-here
JWT_REFRESH_SECRET=change-me-min-32-chars-refresh-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── TrueLayer (open banking — PIS + AIS) ────────────────────────────────────
TRUELAYER_CLIENT_ID=your-truelayer-client-id
TRUELAYER_CLIENT_SECRET=your-truelayer-client-secret
TRUELAYER_REDIRECT_URI=http://localhost:3000/api/callback/truelayer
TRUELAYER_WEBHOOK_SECRET=your-truelayer-webhook-secret
# Sandbox: https://auth.truelayer-sandbox.com — Production: https://auth.truelayer.com
TRUELAYER_AUTH_URL=https://auth.truelayer-sandbox.com
TRUELAYER_API_URL=https://api.truelayer-sandbox.com

# ─── Veriff (KYC — identity verification) ────────────────────────────────────
VERIFF_API_KEY=your-veriff-api-key
VERIFF_SECRET_KEY=your-veriff-secret-key

# ─── Comply Advantage (AML — sanctions + PEP screening) ──────────────────────
COMPLY_ADVANTAGE_API_KEY=your-comply-advantage-api-key
COMPLY_ADVANTAGE_FUZZINESS=0.6

# ─── Notifications ───────────────────────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@bolster.io
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+447700000000

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
INVITE_BASE_URL=http://localhost:3000/invite
INVITE_SECRET=change-me-min-32-chars-invite-signing-secret

# ─── AWS (production only) ────────────────────────────────────────────────────
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_KYC_DOCS=bolster-kyc-documents-prod

# ─── Feature flags ───────────────────────────────────────────────────────────
ENABLE_AML_SCREENING=true
ENABLE_KYC_VERIFICATION=true
ENABLE_PAYMENT_INITIATION=true
MAX_PAYMENT_AMOUNT_PENCE=150000
MIN_PAYMENT_AMOUNT_PENCE=100
BOLSTER_FEE_PERCENTAGE=1.5
BOLSTER_FEE_MIN_PENCE=100
BOLSTER_FEE_MAX_PENCE=1500
